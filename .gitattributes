# ============================================
# UniversalOS .gitattributes
# ============================================
# This file defines attributes for path patterns
# to ensure consistent behavior across platforms

# ============================================
# Auto-detect text files and normalize line endings
# ============================================
* text=auto

# ============================================
# Source Code Files
# ============================================
# C/C++
*.c text diff=cpp
*.cc text diff=cpp
*.cpp text diff=cpp
*.cxx text diff=cpp
*.h text diff=cpp
*.hh text diff=cpp
*.hpp text diff=cpp
*.hxx text diff=cpp

# Rust
*.rs text diff=rust
*.toml text

# Python
*.py text diff=python
*.pyx text diff=python
*.pxd text diff=python
*.pyi text diff=python

# Julia
*.jl text diff=julia

# Assembly
*.s text
*.S text
*.asm text

# ============================================
# Configuration Files
# ============================================
*.json text
*.yaml text
*.yml text
*.xml text
*.ini text
*.cfg text
*.conf text
*.config text

# ============================================
# Documentation Files
# ============================================
*.md text diff=markdown
*.markdown text diff=markdown
*.txt text
*.rst text
*.adoc text

# ============================================
# Script Files
# ============================================
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Makefiles
Makefile text
makefile text
*.mk text
*.make text
GNUmakefile text

# CMake
CMakeLists.txt text
*.cmake text

# ============================================
# Web Files (if used for documentation)
# ============================================
*.html text diff=html
*.htm text diff=html
*.css text diff=css
*.js text
*.jsx text
*.ts text
*.tsx text
*.svg text

# ============================================
# Data Files
# ============================================
*.csv text
*.tsv text
*.sql text

# ============================================
# Binary Files
# ============================================
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.tiff binary
*.tif binary
*.webp binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Compiled binaries
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.o binary
*.obj binary
*.ko binary

# Bootloader and kernel images
*.efi binary
*.img binary
*.iso binary
*.bin binary

# Quantum state files
*.qstate binary
*.qutrit binary
*.mwave binary

# PDF and documents
*.pdf binary
*.doc binary
*.docx binary
*.ppt binary
*.pptx binary
*.xls binary
*.xlsx binary

# Audio files (432Hz audio system)
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.aac binary
*.m4a binary

# Video files
*.mp4 binary
*.avi binary
*.mov binary
*.mkv binary
*.webm binary

# ============================================
# Git LFS (Large File Storage) - if used
# ============================================
# Uncomment if using Git LFS for large files
# *.iso filter=lfs diff=lfs merge=lfs -text
# *.img filter=lfs diff=lfs merge=lfs -text
# *.qstate filter=lfs diff=lfs merge=lfs -text

# ============================================
# Export Ignore
# ============================================
# Files to exclude from git archive exports
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
.kiro/ export-ignore
tests/ export-ignore
docs/ export-ignore

# ============================================
# Diff Settings
# ============================================
# Use better diff algorithms for specific files
*.lock linguist-generated=true
package-lock.json linguist-generated=true
Cargo.lock linguist-generated=true

# ============================================
# Linguist Settings (GitHub language detection)
# ============================================
# Mark documentation as documentation
docs/** linguist-documentation
*.md linguist-documentation

# Mark test files as test code
tests/** linguist-detectable=false

# Mark vendored code
lib/** linguist-vendored

# ============================================
# Merge Strategies
# ============================================
# Use union merge for CHANGELOG
CHANGELOG.md merge=union

# ============================================
# End of File
# ============================================
